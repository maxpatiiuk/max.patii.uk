{
  "name": "@maxpatiiuk/web-components",
  "version": "0.0.1",
  "description": "Shared web components for max.patii.uk",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./loader": "./dist/loader.js",
    "./package.json": "./package.json",
    "./components/*/customElement": "./dist/components/*/customElement.js",
    "./components/*": "./dist/components/*/index.js",
    "./types/*": "./dist/types/*.d.ts",
    "./docs/*": "./dist/docs/*",
    "./cdn/index.css": "./dist/cdn/main.css"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build-dev": "vite build --mode development",
    "watch": "node --run build-dev -- --watch",
    "lint": "lint-staged --config lint-staged.config.js",
    "test-pre": "playwright install --with-deps chromium",
    "test": "node --run test-pre && vitest run --browser.headless",
    "test-debug": "vitest run --no-file-parallelism --no-isolate --inspect",
    "test-watch": "node --run test-pre && vitest"
  },
  "dependencies": {
    "@arcgis/lumina": "5.1.0-next.29",
    "@arcgis/toolkit": "5.1.0-next.29",
    "@lit-labs/ssr": "^4.0.0",
    "lit": "3.3.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@arcgis/lumina-compiler": "5.1.0-next.29",
    "@maxpatiiuk/typescript-config": "workspace:*",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "playwright": "1.58.2",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "css.customData": [
    "dist/docs/vscode.css-custom-data.json"
  ],
  "customElements": "dist/docs/api.json",
  "html.customData": [
    "dist/docs/vscode.html-custom-data.json"
  ],
  "web-types": "dist/docs/web-types.json"
}
